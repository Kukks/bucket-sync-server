      "get": {
        "tags": [
          "BucketSync.Api"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CommitRequest": {
        "required": [
          "ops"
        ],
        "type": "object",
        "properties": {
          "ops": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WriteOpDto"
            }
          }
        }
      },
      "GetRequest": {
        "required": [
          "keys"
        ],
        "type": "object",
        "properties": {
          "keys": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "PasskeyRegisterRequest": {
        "required": [
          "nonce",
          "clientDataJson",
          "attestationObject",
          "device"
        ],
        "type": "object",
        "properties": {
          "nonce": {
            "type": "string"
          },
          "clientDataJson": {
            "type": "string"
          },
          "attestationObject": {
            "type": "string"
          },
          "device": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "PasskeyVerifyRequest": {
        "required": [
          "nonce",
          "credentialId",
          "clientDataJson",
          "authenticatorData",
          "signature",
          "device"
        ],
        "type": "object",
        "properties": {
          "nonce": {
            "type": "string"
          },
          "credentialId": {
            "type": "string"
          },
          "clientDataJson": {
            "type": "string"
          },
          "authenticatorData": {
            "type": "string"
          },
          "signature": {
            "type": "string"
          },
          "device": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "SchnorrAuthRequest": {
        "required": [
          "pubkey",
          "nonce",
          "signature",
          "device"
        ],
        "type": "object",
        "properties": {
          "pubkey": {
            "type": "string"
          },
          "nonce": {
            "type": "string"
          },
          "signature": {
            "type": "string"
          },
          "device": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "WriteOpDto": {
        "required": [
          "key",
          "expectedVersion",
          "scheme",
          "value",
          "delete"
        ],
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "expectedVersion": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          },
          "scheme": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "delete": {
            "type": "boolean"
          }
        }
      }
    }
